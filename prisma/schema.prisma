generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id           String   @id @default(cuid())
  name         String
  age          Int
  gender       String
  blood        String
  phone        String
  email        String?
  address      String?
  dept         String
  doctor       String
  status       String   @default("Stable")
  bedNo        String?
  weight       String?
  height       String?
  diagnosis    String?
  notes        String?
  admittedDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Doctor {
  id        String   @id @default(cuid())
  name      String
  dept      String
  exp       String   @default("0 yrs")
  phone     String
  email     String
  status    String   @default("On Duty")
  shift     String   @default("Morning")
  rating    Float    @default(4.5)
  patients  Int      @default(0)
  education String?
  address   String?
  userId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  password     String
  role         String         @default("Admin")
  phone        String?
  department   String?
  createdAt    DateTime       @default(now())
  activities   UserActivity[]
}

model Staff {
  id        String   @id @default(cuid())
  name      String
  role      String
  dept      String   @default("General")
  shift     String   @default("Morning")
  phone     String   @default("N/A")
  status    String   @default("Active")
  userId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LabReport {
  id          String   @id @default(cuid())
  patientId   String
  patientName String
  testName    String
  result      String
  status      String   @default("Pending")
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
}

model FollowUp {
  id           String   @id @default(cuid())
  patientId    String
  patientName  String
  patientPhone String
  patientEmail String?
  doctorId     String?
  doctorName   String?
  followUpDate DateTime
  status       String   @default("Pending")
  notes        String?
  createdAt    DateTime @default(now())
}

// Tracks every login & registration event for audit
model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String   // "REGISTER" | "LOGIN" | "LOGOUT"
  role      String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model Invoice {
  id           String   @id @default(cuid())
  patientId    String
  patientName  String
  totalAmount  Float
  breakdown    String   // JSON string of room charges, doctor fees, etc.
  status       String   @default("Unpaid") // Unpaid, Paid
  issuedDate   DateTime @default(now())
}

model DischargeSummary {
  id              String   @id @default(cuid())
  patientId       String
  patientName     String
  doctorId        String?
  aiGeneratedText String
  dischargeDate   DateTime @default(now())
}