generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id           String   @id @default(cuid())
  name         String
  age          Int
  gender       String
  blood        String
  phone        String
  email        String?
  address      String?
  dept         String
  doctor       String
  status       String   @default("Stable")
  bedNo        String?
  weight       String?
  height       String?
  diagnosis    String?
  notes        String?
  admittedDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Doctor {
  id        String   @id @default(cuid())
  name      String
  dept      String
  exp       String
  phone     String
  email     String
  status    String   @default("On Duty")
  shift     String
  rating    Float
  patients  Int      @default(0)
  education String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("Admin")
  createdAt DateTime @default(now())
}

model LabReport {
  id          String   @id @default(cuid())
  patientId   String
  patientName String
  testName    String
  result      String
  status      String   @default("Pending")
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
}